# ─── REQUIRED ────────────────────────────────────────────────────────────────

# PostgreSQL password (used by Docker Compose)
POSTGRES_PASSWORD=changeme_use_a_strong_password

# Generate with: openssl rand -hex 32
AUTH_SECRET=

# LLM — provide at least one
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── OPTIONAL ─────────────────────────────────────────────────────────────────

# App URLs (change in production)
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Google OAuth (optional — magic link works without it)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# SMTP for sending magic links
# Leave blank in dev — emails print to console instead
# SMTP_URL=smtp://user:password@smtp.example.com:587
# EMAIL_FROM=coworker@yourdomain.com

# Local file upload directory (default: ./uploads)
# UPLOAD_DIR=./uploads
